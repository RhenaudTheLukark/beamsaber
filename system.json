      "label": "Squad Reputation",
      "type": "Item",
      "system": "beamsaber",
      "path": "packs/crew_reputation"
    },
    {
      "name": "crew_type",
      "label": "Squad Types",
      "type": "Item",
      "system": "beamsaber",
      "path": "packs/crew_types"
    },
    {
      "name": "crew_upgrade",
